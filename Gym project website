<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IronFit Gym</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#111;
color:#fff;
line-height:1.6;
}

header{
background:#000;
padding:20px 10%;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
}

header h1{
color:#ff3c00;
}

nav a{
color:#fff;
text-decoration:none;
margin-left:20px;
font-weight:bold;
}

nav a:hover{
color:#ff3c00;
}

.hero{
height:90vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
background:linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
url("https://images.unsplash.com/photo-1558611848-73f7eb4001ab");
background-size:cover;
background-position:center;
}

.hero h2{
font-size:50px;
margin-bottom:20px;
}

.hero button{
padding:12px 25px;
font-size:18px;
border:none;
background:#ff3c00;
color:#fff;
cursor:pointer;
}

section{
padding:70px 10%;
text-align:center;
}

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
margin-top:40px;
}

.card{
background:#1c1c1c;
padding:30px;
border-radius:10px;
}

.pricing{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:30px;
margin-top:40px;
}

.price-card{
background:#1c1c1c;
padding:30px;
width:250px;
border-radius:10px;
}

.price-card h3{
color:#ff3c00;
margin-bottom:10px;
}

.contact input,
.contact textarea{
width:100%;
padding:10px;
margin:10px 0;
border:none;
border-radius:5px;
}

.contact button{
padding:10px 20px;
border:none;
background:#ff3c00;
color:#fff;
cursor:pointer;
}

footer{
background:#000;
padding:20px;
text-align:center;
margin-top:40px;
}

</style>
</head>

<body>

<header>
<h1>IronFit</h1>
<nav>
<a href="#">Home</a>
<a href="#about">About</a>
<a href="#services">Services</a>
<a href="#pricing">Pricing</a>
<a href="#contact">Contact</a>
</nav>
</header>

<div class="hero">
<div>
<h2>Build Your Dream Body</h2>
<p>Train Hard. Stay Fit. Be Strong.</p>
<br>
<button>Join Now</button>
</div>
</div>

<section id="about">
<h2>About Our Gym</h2>
<p>
IronFit Gym provides world-class equipment, certified trainers,
and personalized workout programs to help you achieve your fitness goals.
</p>
</section>

<section id="services">
<h2>Our Services</h2>

<div class="services">

<div class="card">
<h3>Personal Training</h3>
<p>One-on-one coaching for faster results.</p>
</div>

<div class="card">
<h3>Strength Training</h3>
<p>Build muscle with professional guidance.</p>
</div>

<div class="card">
<h3>Cardio Programs</h3>
<p>Improve endurance and burn fat.</p>
</div>

</div>
</section>

<section id="pricing">
<h2>Membership Plans</h2>

<div class="pricing">

<div class="price-card">
<h3>Basic</h3>
<p>₹999 / month</p>
<p>Gym Access</p>
</div>

<div class="price-card">
<h3>Standard</h3>
<p>₹1999 / month</p>
<p>Gym + Cardio</p>
</div>

<div class="price-card">
<h3>Premium</h3>
<p>₹2999 / month</p>
<p>All Access + Trainer</p>
</div>

</div>
</section>

<section id="contact" class="contact">
<h2>Contact Us</h2>

<form>
<input type="text" placeholder="Your Name" required>
<input type="email" placeholder="Your Email" required>
<textarea rows="5" placeholder="Your Message"></textarea>
<button type="submit">Send Message</button>
</form>

</section>

<footer>
<p>© 2026 IronFit Gym | All Rights Reserved</p>
</footer>

</body>
</html>
