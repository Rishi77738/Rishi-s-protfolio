<!html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PowerFit Gym</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
scroll-behavior:smooth;
}

body{
background:#111;
color:white;
}

/* Navbar */

nav{
position:fixed;
width:100%;
background:#000;
padding:15px 40px;
display:flex;
justify-content:space-between;
align-items:center;
z-index:1000;
}

nav h2{
color:#ff4d4d;
}

nav ul{
list-style:none;
display:flex;
gap:20px;
}

nav ul li a{
text-decoration:none;
color:white;
font-weight:bold;
}

/* Sections */

section{
min-height:100vh;
padding:100px 10%;
display:flex;
flex-direction:column;
justify-content:center;
}

.hero{
background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
url("https://images.unsplash.com/photo-1554284126-aa88f22d8b74") center/cover;
text-align:center;
}

.hero h1{
font-size:60px;
margin-bottom:20px;
}

.hero p{
font-size:20px;
margin-bottom:30px;
}

.btn{
padding:12px 25px;
background:#ff4d4d;
border:none;
color:white;
font-size:16px;
cursor:pointer;
border-radius:5px;
}

/* Facilities */

.facilities{
background:#1a1a1a;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:40px;
}

.card{
background:#222;
padding:25px;
border-radius:10px;
text-align:center;
transition:0.3s;
}

.card:hover{
transform:translateY(-8px);
background:#333;
}

/* Membership */

.membership{
background:#111;
}

.plan-container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
margin-top:40px;
}

.plan{
background:#222;
padding:30px;
border-radius:10px;
text-align:center;
}

.price{
font-size:35px;
margin:15px 0;
color:#ff4d4d;
}

footer{
text-align:center;
padding:20px;
background:#000;
}
</style>
</head>

<body>

<nav>
<h2>PowerFit</h2>
<ul>
<li><a href="#home">Home</a></li>
<li><a href="#facilities">Facilities</a></li>
<li><a href="#membership">Membership</a></li>
</ul>
</nav>

<section class="hero" id="home">
<h1>Build Your Dream Body</h1>
<p>Join the best fitness gym in your city</p>
<button class="btn" onclick="scrollToPlans()">Join Now</button>
</section>

<section class="facilities" id="facilities">
<h2>Our Facilities</h2>

<div class="cards">

<div class="card">
<h3>Modern Equipment</h3>
<p>Latest machines for strength and cardio training.</p>
</div>

<div class="card">
<h3>Personal Training</h3>
<p>Certified trainers to guide your fitness journey.</p>
</div>

<div class="card">
<h3>Yoga Classes</h3>
<p>Improve flexibility and mental wellness.</p>
</div>

<div class="card">
<h3>Locker Rooms</h3>
<p>Clean and secure locker & shower facilities.</p>
</div>

</div>
</section>

<section class="membership" id="membership">
<h2>Membership Plans</h2>

<div class="plan-container">

<div class="plan">
<h3>Basic</h3>
<p class="price">₹250/mo</p>
<p>Gym Access</p>
<p>Locker Room</p>
<br>
<button class="btn">Choose Plan</button>
</div>

<div class="plan">
<h3>Standard</h3>
<p class="price">₹500/mo</p>
<p>Gym Access</p>
<p>Group Classes</p>
<p>Locker Room</p>
<br>
<button class="btn">Choose Plan</button>
</div>

<div class="plan">
<h3>Premium</h3>
<p class="price">₹1000/mo</p>
<p>All Facilities</p>
<p>Personal Trainer</p>
<p>Nutrition Plan</p>
<br>
<button class="btn">Choose Plan</button>
</div>

</div>
</section>

<footer>
<p>© 2026 PowerFit Gym | Stay Strong</p>
</footer>

<script>

function scrollToPlans(){
document.getElementById("membership").scrollIntoView({
behavior:"smooth"
});
}

</script>

</body>
</html>
